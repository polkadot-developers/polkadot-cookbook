<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 640" shape-rendering="crispEdges" role="img" aria-label="Polkadot Cookbook — Build on Polkadot.">
  <!-- Generated. 1280×640 GitHub social preview — readable at thumbnail size. -->
  <rect width="1280" height="640" fill="{{CANVAS}}"/>

  <!-- Pink title slab -->
  <rect x="0" y="0" width="1280" height="400" fill="{{PINK}}"/>
  <text x="80" y="200" font-family="{{MONO}}" font-size="108" font-weight="700" fill="{{TERMINAL}}" letter-spacing="-2">POLKADOT</text>
  <text x="80" y="310" font-family="{{MONO}}" font-size="108" font-weight="700" fill="{{TERMINAL}}" letter-spacing="-2">COOKBOOK</text>
  <rect x="80" y="336" width="460" height="5" fill="{{TERMINAL}}"/>

  <!-- Black tagline + blue KPI -->
  <rect x="0" y="400" width="880" height="240" fill="{{TERMINAL}}"/>
  <text x="80" y="490" font-family="{{MONO}}" font-size="26" fill="{{CREAM}}" opacity="0.9">Practical, tested recipes</text>
  <text x="80" y="528" font-family="{{MONO}}" font-size="26" fill="{{CREAM}}" opacity="0.9">for building on Polkadot.</text>
  <text x="80" y="578" font-family="{{MONO}}" font-size="13" fill="{{CREAM}}" opacity="0.5" letter-spacing="3">PALLETS · CONTRACTS · XCM · TRANSACTIONS · NETWORKS</text>
  <text x="80" y="604" font-family="{{MONO}}" font-size="12" fill="{{CREAM}}" opacity="0.4">+ {{DOCS_HARNESS_COUNT}} tutorial test harnesses from polkadot-docs</text>

  <rect x="880" y="400" width="400" height="240" fill="{{BLUE}}"/>
  <text x="904" y="448" font-family="{{MONO}}" font-size="12" fill="{{CREAM}}" opacity="0.7" letter-spacing="2">v{{VERSION}}</text>
  <text x="904" y="516" font-family="{{MONO}}" font-size="60" font-weight="700" fill="{{CREAM}}">{{RECIPE_COUNT}}</text>
  <text x="904" y="540" font-family="{{MONO}}" font-size="12" fill="{{CREAM}}" opacity="0.7" letter-spacing="2">RECIPES</text>
  <text x="1080" y="516" font-family="{{MONO}}" font-size="60" font-weight="700" fill="{{CREAM}}">{{DOCS_HARNESS_COUNT}}</text>
  <text x="1080" y="540" font-family="{{MONO}}" font-size="12" fill="{{CREAM}}" opacity="0.7" letter-spacing="2">DOCS</text>
  <text x="904" y="602" font-family="{{MONO}}" font-size="11" fill="{{CREAM}}" opacity="0.5">MIT / Apache-2.0</text>
</svg>
