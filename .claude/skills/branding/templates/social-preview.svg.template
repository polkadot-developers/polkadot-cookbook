<svg xmlns="http://www.w3.org/2000/svg" viewBox="0 0 1280 640" shape-rendering="crispEdges" role="img" aria-label="Polkadot Cookbook — Practical, tested recipes for building on Polkadot.">
  <!-- Generated. 1280×640 GitHub social preview.
       EVERGREEN — no version, no counts. Uploaded manually via
       GitHub Settings → Social preview; should not require re-upload
       on each release. -->
  <rect width="1280" height="640" fill="{{CANVAS}}"/>

  <!-- Pink title slab -->
  <rect x="0" y="0" width="1280" height="460" fill="{{PINK}}"/>
  <text x="80" y="230" font-family="{{MONO}}" font-size="124" font-weight="700" fill="{{TERMINAL}}" letter-spacing="-2">POLKADOT</text>
  <text x="80" y="360" font-family="{{MONO}}" font-size="124" font-weight="700" fill="{{TERMINAL}}" letter-spacing="-2">COOKBOOK</text>
  <rect x="80" y="388" width="540" height="5" fill="{{TERMINAL}}"/>
  <text x="80" y="434" font-family="{{MONO}}" font-size="24" fill="{{TERMINAL}}" opacity="0.9">Practical, tested recipes for building on Polkadot.</text>

